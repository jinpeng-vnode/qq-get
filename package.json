{
  "name": "qq-get",
  "version": "1.0.0",
  "description": "Collect QQ messages from Windows notifications.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron . --dev-server=http://127.0.0.1:5173",
    "build": "vite build",
    "start": "electron .",
    "collector:once": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts\\qq-notification-collector.ps1 -Once"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "antd": "^6.4.5",
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
